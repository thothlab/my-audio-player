<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Тема запуска: фон окна и системный сплеш (Android 12+) — «слива», как у брендового
      Compose-сплеша. Иначе перед ним мелькает серый системный сплеш (резкая смена экрана).
    -->
    <style name="Theme.Dombra" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_plum</item>
        <item name="android:statusBarColor">@color/splash_plum</item>
        <item name="android:navigationBarColor">@color/splash_plum</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/splash_plum</item>
    </style>
</resources>
